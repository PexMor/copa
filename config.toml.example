# copa configuration example
#
# Copy to: ~/.config/copa/config.toml
#
#   mkdir -p ~/.config/copa
#   cp config.toml.example ~/.config/copa/config.toml
#
# Precedence: CLI args > environment variables > config file > defaults

# ── Server (copasrv) ──────────────────────────────────────────────────────────

[server]
# Port to listen on (default: 8080)
port = 8080

# Bind address (default: 127.0.0.1 — change to 0.0.0.0 to expose on network)
bind = "127.0.0.1"

# Named clipboard namespaces. Each namespace is independent with its own:
#   - size_limit: max content size in bytes (default: 16384 = 16 KB)
#   - read_token:  token granting read-only access
#   - write_token: token granting write-only access
#   - rw_token:    token granting read+write access
# At least one token per namespace is required; any combination is valid.

[server.namespaces.default]
size_limit = 16384
rw_token = "your-rw-token-here"          # generate: copasrv --generate-token

# Optional extra namespace with separate tokens
[server.namespaces.shared]
size_limit = 4096
read_token  = "reader-token-here"
write_token = "writer-token-here"

# Large namespace example
# [server.namespaces.files]
# size_limit = 65536
# rw_token = "files-token-here"

# Legacy single-token shorthand (maps to default namespace rw_token):
# token = "your-token-here"

# ── Client (copacli) ──────────────────────────────────────────────────────────

[cli]
# Default remote to use when --remote is not specified
default_remote = "local"

[cli.remotes.local]
url   = "http://127.0.0.1:8080"
token = "your-rw-token-here"

[cli.remotes.work]
url   = "https://copa.example.com"
token = "work-token-here"
# Optional extra headers forwarded with every request
headers = { "X-Custom-Header" = "value" }

# Usage:
#   copasrv                                  start server
#   copacli copy -r local                    download default ns → tmux buffer
#   copacli copy -r local --namespace shared download shared ns → tmux buffer
#   copacli copy -r local --output-cmd pbcopy               → macOS clipboard
#   copacli copy -r local --output-cmd 'xsel -ib'           → X11 clipboard
#   copacli copy -r local --output-cmd wl-copy              → Wayland clipboard
#   copacli copy -r local -o -                              → stdout
#   copacli paste -r local                   upload tmux buffer → default ns
#   copacli paste -r local --input-cmd pbpaste               ← macOS clipboard
#   copacli paste -r local "text"            upload literal text
#   echo data | copacli paste -r local       upload stdin
#   copacli watch -r local                   live WebSocket → tmux buffer (runs forever)
#   copacli watch -r local --output-cmd pbcopy  live → macOS clipboard
